<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@color/background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Customer Reminder"
        android:textAppearance="@style/TextAppearance.AppCompat.Large"
        android:textStyle="bold"
        android:paddingBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add customers, schedule reminders, and view pending phases."
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:paddingBottom="24dp" />

    <Button
        android:id="@+id/buttonRegisterCustomer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Register Customer" />

    <Button
        android:id="@+id/buttonCustomers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View Customers"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/buttonReminders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View Reminders"
        android:layout_marginTop="16dp" />
</LinearLayout>
